{
  "$defs": {
    "AssetRef": {
      "additionalProperties": false,
      "properties": {
        "asset_id": {
          "title": "Asset Id",
          "type": "string"
        },
        "uri": {
          "title": "Uri",
          "type": "string"
        },
        "media_type": {
          "title": "Media Type",
          "type": "string"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        },
        "width_px": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Width Px"
        },
        "height_px": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Height Px"
        }
      },
      "required": [
        "asset_id",
        "uri",
        "media_type",
        "sha256"
      ],
      "title": "AssetRef",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "captcha-classification-request/v1",
      "title": "Schema Version",
      "type": "string"
    },
    "request_id": {
      "title": "Request Id",
      "type": "string"
    },
    "assets": {
      "items": {
        "$ref": "#/$defs/AssetRef"
      },
      "title": "Assets",
      "type": "array"
    },
    "context": {
      "additionalProperties": true,
      "title": "Context",
      "type": "object"
    },
    "authorization_record_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Authorization Record Id"
    }
  },
  "required": [
    "request_id",
    "assets"
  ],
  "title": "ClassificationRequest",
  "type": "object"
}
