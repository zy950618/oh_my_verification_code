{
  "$defs": {
    "AssetRef": {
      "additionalProperties": false,
      "properties": {
        "asset_id": {
          "title": "Asset Id",
          "type": "string"
        },
        "uri": {
          "title": "Uri",
          "type": "string"
        },
        "media_type": {
          "title": "Media Type",
          "type": "string"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        },
        "width_px": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Width Px"
        },
        "height_px": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Height Px"
        }
      },
      "required": [
        "asset_id",
        "uri",
        "media_type",
        "sha256"
      ],
      "title": "AssetRef",
      "type": "object"
    },
    "ChallengeFamily": {
      "enum": [
        "unknown",
        "slider",
        "rotate",
        "click"
      ],
      "title": "ChallengeFamily",
      "type": "string"
    },
    "SolutionType": {
      "enum": [
        "text",
        "points",
        "tiles",
        "offset",
        "angle",
        "track",
        "press"
      ],
      "title": "SolutionType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "captcha-solve-request/v1",
      "title": "Schema Version",
      "type": "string"
    },
    "request_id": {
      "title": "Request Id",
      "type": "string"
    },
    "challenge_instance_id": {
      "title": "Challenge Instance Id",
      "type": "string"
    },
    "challenge_family": {
      "$ref": "#/$defs/ChallengeFamily"
    },
    "assets": {
      "items": {
        "$ref": "#/$defs/AssetRef"
      },
      "title": "Assets",
      "type": "array"
    },
    "allowed_solution_types": {
      "items": {
        "$ref": "#/$defs/SolutionType"
      },
      "title": "Allowed Solution Types",
      "type": "array"
    },
    "classification_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Classification Id"
    },
    "classification_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Classification Hash"
    },
    "classification_confidence": {
      "anyOf": [
        {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Classification Confidence"
    },
    "solver_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Solver Id"
    },
    "authorization_record_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Authorization Record Id"
    },
    "expires_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Expires At"
    }
  },
  "required": [
    "request_id",
    "challenge_instance_id",
    "challenge_family",
    "assets",
    "allowed_solution_types"
  ],
  "title": "SolveRequest",
  "type": "object"
}
