{
  "$defs": {
    "Action": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/ActionKind"
        },
        "time_ms": {
          "minimum": 0,
          "title": "Time Ms",
          "type": "integer"
        },
        "x": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "X"
        },
        "y": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Y"
        },
        "text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Text"
        },
        "duration_ms": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Duration Ms"
        },
        "angle_degrees": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Angle Degrees"
        }
      },
      "required": [
        "kind",
        "time_ms"
      ],
      "title": "Action",
      "type": "object"
    },
    "ActionKind": {
      "enum": [
        "pointer_down",
        "pointer_move",
        "pointer_up",
        "tap",
        "click",
        "wait",
        "type_text",
        "press",
        "rotate"
      ],
      "title": "ActionKind",
      "type": "string"
    },
    "ArtifactBinding": {
      "additionalProperties": false,
      "properties": {
        "registry_kind": {
          "enum": [
            "classifier",
            "solver",
            "model",
            "dataset",
            "action",
            "target",
            "evidence"
          ],
          "title": "Registry Kind",
          "type": "string"
        },
        "entry_id": {
          "title": "Entry Id",
          "type": "string"
        },
        "version": {
          "title": "Version",
          "type": "string"
        },
        "artifact_hash": {
          "title": "Artifact Hash",
          "type": "string"
        }
      },
      "required": [
        "registry_kind",
        "entry_id",
        "version",
        "artifact_hash"
      ],
      "title": "ArtifactBinding",
      "type": "object"
    },
    "CaptureSpace": {
      "enum": [
        "intrinsic_image_px",
        "screenshot_device_px"
      ],
      "title": "CaptureSpace",
      "type": "string"
    },
    "CoordinateFrame": {
      "additionalProperties": false,
      "properties": {
        "width": {
          "exclusiveMinimum": 0,
          "title": "Width",
          "type": "number"
        },
        "height": {
          "exclusiveMinimum": 0,
          "title": "Height",
          "type": "number"
        },
        "device_pixel_ratio": {
          "exclusiveMinimum": 0,
          "title": "Device Pixel Ratio",
          "type": "number"
        },
        "capture_space": {
          "$ref": "#/$defs/CaptureSpace",
          "default": "intrinsic_image_px"
        },
        "intrinsic_width": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Intrinsic Width"
        },
        "intrinsic_height": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Intrinsic Height"
        },
        "crop_x": {
          "default": 0,
          "title": "Crop X",
          "type": "number"
        },
        "crop_y": {
          "default": 0,
          "title": "Crop Y",
          "type": "number"
        },
        "rendered_x": {
          "default": 0,
          "title": "Rendered X",
          "type": "number"
        },
        "rendered_y": {
          "default": 0,
          "title": "Rendered Y",
          "type": "number"
        },
        "rendered_width": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rendered Width"
        },
        "rendered_height": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rendered Height"
        },
        "scroll_x": {
          "default": 0,
          "title": "Scroll X",
          "type": "number"
        },
        "scroll_y": {
          "default": 0,
          "title": "Scroll Y",
          "type": "number"
        },
        "iframe_x": {
          "default": 0,
          "title": "Iframe X",
          "type": "number"
        },
        "iframe_y": {
          "default": 0,
          "title": "Iframe Y",
          "type": "number"
        },
        "frame_chain": {
          "items": {
            "$ref": "#/$defs/FrameTransform"
          },
          "title": "Frame Chain",
          "type": "array"
        },
        "rounding": {
          "default": "nearest",
          "enum": [
            "nearest",
            "floor",
            "ceil"
          ],
          "title": "Rounding",
          "type": "string"
        }
      },
      "required": [
        "width",
        "height",
        "device_pixel_ratio"
      ],
      "title": "CoordinateFrame",
      "type": "object"
    },
    "FrameTransform": {
      "additionalProperties": false,
      "properties": {
        "frame_id": {
          "title": "Frame Id",
          "type": "string"
        },
        "offset_x": {
          "default": 0,
          "title": "Offset X",
          "type": "number"
        },
        "offset_y": {
          "default": 0,
          "title": "Offset Y",
          "type": "number"
        },
        "scroll_x": {
          "default": 0,
          "title": "Scroll X",
          "type": "number"
        },
        "scroll_y": {
          "default": 0,
          "title": "Scroll Y",
          "type": "number"
        },
        "border_x": {
          "default": 0,
          "title": "Border X",
          "type": "number"
        },
        "border_y": {
          "default": 0,
          "title": "Border Y",
          "type": "number"
        }
      },
      "required": [
        "frame_id"
      ],
      "title": "FrameTransform",
      "type": "object"
    },
    "TransformRecord": {
      "additionalProperties": false,
      "properties": {
        "step": {
          "title": "Step",
          "type": "string"
        },
        "input_x": {
          "title": "Input X",
          "type": "number"
        },
        "input_y": {
          "title": "Input Y",
          "type": "number"
        },
        "output_x": {
          "title": "Output X",
          "type": "number"
        },
        "output_y": {
          "title": "Output Y",
          "type": "number"
        },
        "details": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "string"
              }
            ]
          },
          "title": "Details",
          "type": "object"
        }
      },
      "required": [
        "step",
        "input_x",
        "input_y",
        "output_x",
        "output_y"
      ],
      "title": "TransformRecord",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "captcha-action-plan/v1",
      "title": "Schema Version",
      "type": "string"
    },
    "plan_id": {
      "title": "Plan Id",
      "type": "string"
    },
    "challenge_instance_id": {
      "title": "Challenge Instance Id",
      "type": "string"
    },
    "source_prediction_id": {
      "title": "Source Prediction Id",
      "type": "string"
    },
    "source_prediction_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Prediction Hash"
    },
    "input_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Input Hash"
    },
    "session_binding_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Session Binding Hash"
    },
    "target_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Target Id"
    },
    "planner_binding": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactBinding"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "coordinate_frame": {
      "$ref": "#/$defs/CoordinateFrame"
    },
    "transforms": {
      "items": {
        "$ref": "#/$defs/TransformRecord"
      },
      "title": "Transforms",
      "type": "array"
    },
    "actions": {
      "items": {
        "$ref": "#/$defs/Action"
      },
      "title": "Actions",
      "type": "array"
    },
    "constraints": {
      "items": {
        "type": "string"
      },
      "title": "Constraints",
      "type": "array"
    },
    "stop_conditions": {
      "items": {
        "type": "string"
      },
      "title": "Stop Conditions",
      "type": "array"
    },
    "maximum_action_count": {
      "default": 16,
      "exclusiveMinimum": 0,
      "title": "Maximum Action Count",
      "type": "integer"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "expires_at": {
      "format": "date-time",
      "title": "Expires At",
      "type": "string"
    },
    "authorization_record_id": {
      "title": "Authorization Record Id",
      "type": "string"
    },
    "plan_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Plan Hash"
    },
    "executable": {
      "const": false,
      "default": false,
      "title": "Executable",
      "type": "boolean"
    }
  },
  "required": [
    "plan_id",
    "challenge_instance_id",
    "source_prediction_id",
    "coordinate_frame",
    "actions",
    "stop_conditions",
    "created_at",
    "expires_at",
    "authorization_record_id"
  ],
  "title": "ActionPlan",
  "type": "object"
}
